#!/bin/sh
#
# S50-legacy-bridge — start the inv-driver UDS subscriber that
# materialises /tmp/parameters_app.conf for legacy consumers
# (ecu-sunspec, etc.). Runs after S48-inv-driver so the socket is
# ready; the bridge retries with backoff if it dials too early.
#
# Install:
#   ssh ecu 'cat > /etc/rcS.d/S50-legacy-bridge' < S50-legacy-bridge
#   ssh ecu 'chmod +x /etc/rcS.d/S50-legacy-bridge'
#
# State paths:
#   /var/run/inv-driver.sock                              UDS endpoint
#   /tmp/parameters_app.conf                              params snapshot
#   /home/applications/legacy-bridge/legacy-bridge.log    stdout/stderr

BIN=/home/applications/legacy-bridge/legacy-bridge
RUN=/home/applications/legacy-bridge
LOG=$RUN/legacy-bridge.log
PIDFILE=$RUN/legacy-bridge.pid
SOCK=/var/run/inv-driver.sock
PARAMS=/tmp/parameters_app.conf
ARGS="--socket $SOCK --params-file $PARAMS"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "legacy-bridge already running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    [ -x "$BIN" ] || { echo "$BIN missing or not executable"; return 1; }
    mkdir -p "$RUN"

    # nohup-sh-exec wrapper: same pattern as S48-inv-driver / S49-ecu-zb,
    # so the bridge survives both init(1) boot context and PHP-FPM
    # upgrade-endpoint context. The inner exec lets the wrapper sh be
    # replaced by legacy-bridge so the captured PID is the right one.
    nohup sh -c "echo \$\$ > '$PIDFILE'; exec '$BIN' $ARGS" \
        </dev/null >> "$LOG" 2>&1 &
    sleep 1
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "legacy-bridge started (pid $(cat "$PIDFILE"))"
    else
        echo "legacy-bridge failed to stay up; check $LOG"
        return 1
    fi
}

stop() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        kill "$PID" 2>/dev/null
        sleep 2
        kill -9 "$PID" 2>/dev/null
        rm -f "$PIDFILE"
        echo "legacy-bridge stopped"
    else
        P=$(pidof legacy-bridge 2>/dev/null)
        if [ -n "$P" ]; then
            kill $P 2>/dev/null
            sleep 2
            kill -9 $P 2>/dev/null
            echo "legacy-bridge stopped (no pidfile, used pidof)"
        else
            echo "legacy-bridge not running"
        fi
    fi
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "running (pid $(cat "$PIDFILE"))"
    else
        echo "stopped"
        exit 1
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)
        echo "usage: $0 {start|stop|restart|status}"
        exit 2
        ;;
esac
