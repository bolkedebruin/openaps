#!/bin/sh
# postinst — openaps-tls-proxy
#
# Keep opkg's download scratch on /home (the 3.5G root fs) so the 16 MiB /tmp
# tmpfs never overflows, then bring the proxy up. The opkg feed config
# (/etc/opkg/openaps.conf) and the operator-editable upstream
# (/etc/openaps/feed.conf) are shipped as conffiles, so opkg installs and
# preserves them across upgrades — this script does not write them.
set -e

mkdir -p /home/openaps/opkg-tmp /home/openaps/opkg-cache

# Bring the persistent proxy up now (it also starts at boot via rcS.d S47).
[ -x /etc/rcS.d/S47-openaps-tls-proxy ] && /etc/rcS.d/S47-openaps-tls-proxy start

exit 0
