#!/bin/sh
#
# openaps-base postinst — provision /etc/inv-driver/settings.json from the
# stock /etc/yuneng/*.conf provisioning files at install time, so the ecu_id
# lives in inv-driver's own config and no app reads ecuid.conf at runtime.
# Idempotent: an existing settings.json is kept (operator edits win), except
# an EMPTY ecu_id is backfilled from the factory serial so the SunSpec SN /
# dashboard id isn't blank.
set -e

SETTINGS_PATH=/etc/inv-driver/settings.json
MAC_CONF=/etc/yuneng/ecu_eth0_mac.conf
ECUID_CONF=/etc/yuneng/ecuid.conf

mkdir -p /etc/openaps /etc/inv-driver

# read_ecu_id echoes the factory serial from ecuid.conf, sanitised to the
# JSON-safe allowlist ([0-9A-Za-z_-]); empty when absent or unparseable.
read_ecu_id() {
    _id=""
    if [ -f "$ECUID_CONF" ]; then
        _id=$(cat "$ECUID_CONF" 2>/dev/null | tr -d '[:space:]')
    fi
    case "$_id" in *[!0-9A-Za-z_-]*) _id= ;; esac
    printf '%s' "$_id"
}

if [ -f "$SETTINGS_PATH" ]; then
    # Keep operator-edited config, but backfill an empty ecu_id (the only
    # field touched; all others are preserved).
    if grep -qE '"ecu_id"[[:space:]]*:[[:space:]]*""' "$SETTINGS_PATH"; then
        ECU_ID=$(read_ecu_id)
        if [ -n "$ECU_ID" ]; then
            sed 's#"ecu_id"[[:space:]]*:[[:space:]]*""#"ecu_id": "'"$ECU_ID"'"#' \
                "$SETTINGS_PATH" > "$SETTINGS_PATH.new"
            chmod 0600 "$SETTINGS_PATH.new"
            mv "$SETTINGS_PATH.new" "$SETTINGS_PATH"
            echo "openaps-base: backfilled empty ecu_id=$ECU_ID in $SETTINGS_PATH"
        else
            echo "openaps-base: $SETTINGS_PATH ecu_id empty and no factory serial to seed it"
        fi
    else
        echo "openaps-base: $SETTINGS_PATH already exists — keeping operator-edited config"
    fi
    exit 0
fi

if [ ! -f "$MAC_CONF" ]; then
    echo "openaps-base: $MAC_CONF missing — settings.json left for first-run autodetect"
    exit 0
fi

# Build a fresh settings.json from /etc/yuneng/ecu_eth0_mac.conf +
# /etc/yuneng/ecuid.conf. Format expected by inv-driver internal/settings.
MAC_RAW=$(cat "$MAC_CONF" 2>/dev/null | tr -d '[:space:]' | head -c 32)
MAC_HEX=$(echo "$MAC_RAW" | tr -d ':-' | tr 'A-F' 'a-f')
if [ -z "$MAC_HEX" ] || [ ${#MAC_HEX} -lt 12 ]; then
    echo "openaps-base: $MAC_CONF content unparseable; settings.json left for first-run autodetect"
    exit 0
fi

# Lower 16 bits of MAC -> PAN override (uppercase hex, 4 chars).
PAN_HEX=$(echo "$MAC_HEX" | tail -c 5 | tr 'a-f' 'A-F')
# Re-format MAC as colon-separated for cosmetics.
MAC_FMT=$(echo "$MAC_HEX" | sed 's/\(..\)/\1:/g;s/:$//')
ECU_ID=$(read_ecu_id)

# Allowlist each yuneng-derived value substituted UNQUOTED into JSON: reject
# anything outside [0-9A-Za-z_-] (so quotes, backslashes, control chars or
# whitespace can never malform/inject the generated settings.json).
case "$PAN_HEX" in *[!0-9A-Za-z_-]*) PAN_HEX= ;; esac
case "$MAC_FMT" in *[!0-9A-Za-z:_-]*) MAC_FMT= ;; esac

cat > "$SETTINGS_PATH.new" <<EOF
{
  "ecu_id": "$ECU_ID",
  "mac": "$MAC_FMT",
  "pan_override": "$PAN_HEX",
  "zigbee_type": "apsystems",
  "channel": 16
}
EOF
chmod 0600 "$SETTINGS_PATH.new"
mv "$SETTINGS_PATH.new" "$SETTINGS_PATH"
echo "openaps-base: + $SETTINGS_PATH (ecu_id=$ECU_ID mac=$MAC_FMT pan=$PAN_HEX)"

exit 0
