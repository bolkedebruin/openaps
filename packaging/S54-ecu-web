#!/bin/sh
#
# S54-ecu-web — start the ecu-web operator console after inv-driver
# (S48) so its UDS socket exists when ecu-web's subscriber first dials.
# ecu-web is a pure UDS client of inv-driver and serves an HTTP/2 TLS
# web UI on :443.
#
# Install:
#   ssh ecu 'cat > /etc/rcS.d/S54-ecu-web' < S54-ecu-web
#   ssh ecu 'chmod +x /etc/rcS.d/S54-ecu-web'
#
# State paths (ecu-web's state dir):
#   /var/lib/ecu-web/cert.pem,key.pem   self-signed TLS material (auto-gen)
#   /var/lib/ecu-web/auth.json          operator password hash
#   /var/log/ecu-web.log                rotated log (binary-owned)

BIN=/home/applications/ecu-web/ecu-web
STATE=/var/lib/ecu-web
SOCK=/var/run/inv-driver.sock
RUN=/home/applications/ecu-web
# ecu-web owns its rotated log via -log-file; the init redirect only captures
# pre-logging flag errors and Go runtime panics.
LOG=/var/log/ecu-web.log
BOOTLOG=/var/log/ecu-web.boot.log
PIDFILE=$RUN/ecu-web.pid
ARGS="-listen :443 -invdriver-sock $SOCK -state-dir $STATE -backend ecu-web -log-file $LOG"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "ecu-web already running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    [ -x "$BIN" ] || { echo "$BIN missing or not executable"; return 1; }
    mkdir -p "$STATE" "$RUN" /var/log

    # nohup-sh-exec wrapper: same pattern as S48-inv-driver, so the
    # daemon survives both init(1) boot context and the PHP-FPM
    # upgrade-endpoint context. The inner exec replaces the wrapper sh
    # with ecu-web so the captured PID is the right one.
    nohup sh -c "echo \$\$ > '$PIDFILE'; exec '$BIN' $ARGS" \
        </dev/null >> "$BOOTLOG" 2>&1 &
    sleep 1
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "ecu-web started (pid $(cat "$PIDFILE")) — https on :443"
    else
        echo "ecu-web failed to stay up; check $LOG"
        return 1
    fi
}

stop() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        kill "$PID" 2>/dev/null
        sleep 2
        kill -9 "$PID" 2>/dev/null
        rm -f "$PIDFILE"
        echo "ecu-web stopped"
    else
        P=$(pidof ecu-web 2>/dev/null)
        if [ -n "$P" ]; then
            kill $P 2>/dev/null
            sleep 2
            kill -9 $P 2>/dev/null
            echo "ecu-web stopped (no pidfile, used pidof)"
        else
            echo "ecu-web not running"
        fi
    fi
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "running (pid $(cat "$PIDFILE"))"
    else
        echo "stopped"
        exit 1
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)
        echo "usage: $0 {start|stop|restart|status}"
        exit 2
        ;;
esac
