#!/bin/sh
#
# S97-recoveryd — start recoveryd BEFORE S98-dropbear so the .ssh dir and
# the dropbear host key are in place before dropbear binds :22. recoveryd
# is the single writer of root's ~/.ssh/authorized_keys, which is itself the
# source of truth — recoveryd reads and rewrites it directly and serves a
# root-only local UDS for the web console. No -authorized-keys flag is
# passed, so recoveryd resolves root's REAL home dir from /etc/passwd
# (/home/root on the ECU) — the file dropbear actually authenticates against.
#
# Install:
#   ssh ecu 'cat > /etc/rcS.d/S97-recoveryd' < S97-recoveryd
#   ssh ecu 'chmod +x /etc/rcS.d/S97-recoveryd'
#
# State paths:
#   ~root/.ssh/authorized_keys       key file (mode 0600), the source of truth
#   /var/run/recoveryd.sock          UDS endpoint (mode 0600, root-only)
#   /var/log/recoveryd.log           rotated log (binary-owned)

BIN=/home/applications/recoveryd/recoveryd
SOCK=/var/run/recoveryd.sock
RUN=/home/applications/recoveryd
# recoveryd owns its rotated log via -log-file; the init redirect only captures
# pre-logging flag errors and Go runtime panics.
LOG=/var/log/recoveryd.log
BOOTLOG=/var/log/recoveryd.boot.log
PIDFILE=$RUN/recoveryd.pid
ARGS="-manage-dropbear=true -socket $SOCK -log-file $LOG"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "recoveryd already running (pid $(cat "$PIDFILE"))"
        return 0
    fi
    [ -x "$BIN" ] || { echo "$BIN missing or not executable"; return 1; }
    mkdir -p "$RUN" /var/log

    # Ensure root's home dir is root-owned and not group/other-writable before
    # dropbear authenticates against ~/.ssh/authorized_keys. dropbear (like
    # OpenSSH StrictModes) rejects a key when the home dir CONTAINING .ssh is
    # owned by another uid or is group/other-writable — recoveryd ensures .ssh
    # and authorized_keys themselves, but not the directory above them. A box
    # whose /home/root was chowned to an app user silently falls through to
    # password despite a correct key; fixing it here self-heals on every boot.
    ROOT_HOME=$(awk -F: '$1=="root"{print $6; exit}' /etc/passwd 2>/dev/null)
    [ -n "$ROOT_HOME" ] || ROOT_HOME=/home/root
    if [ -d "$ROOT_HOME" ]; then
        chown root:root "$ROOT_HOME" 2>/dev/null || true
        chmod go-w "$ROOT_HOME" 2>/dev/null || true
    fi

    # nohup-sh-exec wrapper: same pattern as S48-inv-driver / S98-dropbear,
    # so the daemon survives both init(1) boot context and a PHP-FPM
    # upgrade-endpoint context. The inner exec replaces the wrapper sh with
    # recoveryd so the captured PID is the right one.
    nohup sh -c "echo \$\$ > '$PIDFILE'; exec '$BIN' $ARGS" \
        </dev/null >> "$BOOTLOG" 2>&1 &
    sleep 1
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "recoveryd started (pid $(cat "$PIDFILE"))"
    else
        echo "recoveryd failed to stay up; check $LOG"
        return 1
    fi

    # Wait for the socket so the web console can connect.
    i=0
    while [ $i -lt 10 ]; do
        if [ -S "$SOCK" ]; then
            echo "recoveryd ready: $SOCK"
            return 0
        fi
        sleep 1
        i=$((i+1))
    done
    echo "recoveryd did not publish socket within 10s"
    return 1
}

stop() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        kill "$PID" 2>/dev/null
        sleep 2
        kill -9 "$PID" 2>/dev/null
        rm -f "$PIDFILE"
        echo "recoveryd stopped"
    else
        P=$(pidof recoveryd 2>/dev/null)
        if [ -n "$P" ]; then
            kill $P 2>/dev/null
            sleep 2
            kill -9 $P 2>/dev/null
            echo "recoveryd stopped (no pidfile, used pidof)"
        else
            echo "recoveryd not running"
        fi
    fi
    rm -f "$SOCK"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "running (pid $(cat "$PIDFILE"))"
    else
        echo "stopped"
        exit 1
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)
        echo "usage: $0 {start|stop|restart|status}"
        exit 2
        ;;
esac
