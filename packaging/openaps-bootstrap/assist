#!/bin/sh
#
# assist — OpenAPS bootstrap orchestrator. POSIX sh, BusyBox-safe.
#
# Run by the stock APsystems lighttpd/CodeIgniter hidden endpoint
# exec_upgrade_ecu_app (POST /index.php/management/exec_upgrade_ecu_app),
# which extracts this tarball and runs the script named "assist" at its root.
#
# This is the brownfield foothold and it is PURELY ADDITIVE: it plants the trust
# anchor + root access, brings up dropbear and the openaps-tls-proxy from LOCAL
# .ipks (no network), and wires up the networked opkg feed. It does NOT touch the
# stock firmware — it does not disable the stock supervisors and does not remove
# lighttpd/CodeIgniter; the stock stack keeps running alongside. It also does not
# install the OpenAPS firmware packages — it leaves the operator a one-liner to
# do that over the now-authenticated opkg feed (which is what disables stock).
#
# Payload layout (siblings of this script at the tarball root):
#   assist
#   ipks/openaps-dropbear_<ver>_armv7ahf-vfp-neon.ipk
#   ipks/openaps-tls-proxy_<ver>_armv7ahf-vfp-neon.ipk
#   release.pub          -> /etc/openaps/release.pub
#   authorized_keys      -> /home/root/.ssh/authorized_keys
#   opkg-openaps.conf    -> /etc/opkg/openaps.conf
#   root.shadow.hash     ($6$ SHA-512 crypt hash, one line)
#
# Idempotent: re-running over the same box is safe.
#
# Logs to /home/openaps-bootstrap.log.

set -eu

# This orchestrator is launched by PHP under lighttpd (the stock
# exec_upgrade_ecu_app endpoint), so it is a member of lighttpd's process group.
# If lighttpd is restarted/reloaded mid-run, the group teardown would otherwise
# signal and terminate this script. Ignore HUP and TERM so the bootstrap runs to
# completion regardless of who launched us. Re-armed below alongside the
# lock-cleanup EXIT trap once $STATE_DIR exists.
trap '' HUP TERM

# Stamped by `make package-bootstrap` (sed-substitutes this line with the build
# version). The literal default is the fallback when run unpackaged.
VERSION="__OPENAPS_VERSION__"
case "$VERSION" in __OPENAPS_VERSION__|"") VERSION="dev" ;; esac

LOG=/home/openaps-bootstrap.log
STATE_DIR=/etc/openaps
RELEASE_KEY=$STATE_DIR/release.pub
MAC_CONF=/etc/yuneng/ecu_eth0_mac.conf
OPKG_CONF=/etc/opkg/openaps.conf
NEED_KB=51200    # ~50 MB in /home (opkg scratch lives here, not /tmp)
NEED_ETC_KB=256  # rootfs headroom for the /etc/shadow + /etc/opkg temp+mv edits

exec >> "$LOG" 2>&1
echo
echo "=== $(date) openaps-bootstrap $VERSION starting ==="

BOOT_DIR=$(cd "$(dirname "$0")" && pwd)
IPK_DIR=$BOOT_DIR/ipks

if [ ! -d "$IPK_DIR" ]; then
    echo "FATAL: payload directory $IPK_DIR not found"
    exit 1
fi

# Resolve the two bundled .ipks by glob so the build version isn't hardcoded.
DROPBEAR_IPK=""
for f in "$IPK_DIR"/openaps-dropbear_*_armv7ahf-vfp-neon.ipk; do
    [ -f "$f" ] && DROPBEAR_IPK=$f
done
TLSPROXY_IPK=""
for f in "$IPK_DIR"/openaps-tls-proxy_*_armv7ahf-vfp-neon.ipk; do
    [ -f "$f" ] && TLSPROXY_IPK=$f
done

# ---------------------------------------------------------------------------
# Step 1 — pre-flight + lock + backup
# ---------------------------------------------------------------------------
echo "--- step 1: pre-flight + lock + backup ---"

# Disk: BusyBox df -k. Available column = 4th field on the data line.
AVAIL=$(df -k /home 2>/dev/null | awk 'NR==2 {print $4}')
if [ -z "$AVAIL" ] || [ "$AVAIL" -lt "$NEED_KB" ]; then
    echo "FATAL: insufficient free space in /home (have ${AVAIL:-0} KB, need $NEED_KB KB)"
    exit 1
fi
echo "  disk ok: ${AVAIL} KB free in /home"

# The /etc edits (shadow + opkg) write a temp on the same filesystem as /etc
# before the atomic mv, so the rootfs needs its own headroom; the /home check
# above does not cover it when /etc is a separate mount.
AVAIL_ETC=$(df -k /etc 2>/dev/null | awk 'NR==2 {print $4}')
if [ -z "$AVAIL_ETC" ] || [ "$AVAIL_ETC" -lt "$NEED_ETC_KB" ]; then
    echo "FATAL: insufficient free space on the /etc filesystem (have ${AVAIL_ETC:-0} KB, need $NEED_ETC_KB KB)"
    exit 1
fi
echo "  disk ok: ${AVAIL_ETC} KB free on the /etc filesystem"

if [ ! -f "$MAC_CONF" ]; then
    echo "FATAL: $MAC_CONF missing — ECU not provisioned"
    exit 1
fi
echo "  $MAC_CONF present"

if [ -z "$DROPBEAR_IPK" ]; then
    echo "FATAL: no openaps-dropbear_*_armv7ahf-vfp-neon.ipk in $IPK_DIR"
    exit 1
fi
if [ -z "$TLSPROXY_IPK" ]; then
    echo "FATAL: no openaps-tls-proxy_*_armv7ahf-vfp-neon.ipk in $IPK_DIR"
    exit 1
fi
echo "  dropbear ipk:  $DROPBEAR_IPK"
echo "  tls-proxy ipk: $TLSPROXY_IPK"

# .ipk is an ar(1) archive whose first member is "debian-binary" — magic "!<arch>".
# The ECU's BusyBox od (v1.20.x) does NOT support -A/-t/-N (only the flags in
# `od [-aBbcDdeFfHhIiLlOovXx]`), so we read the first bytes and render with plain
# `od -c`, glob-matching the ar magic anywhere in the rendered line.
for ipk in "$DROPBEAR_IPK" "$TLSPROXY_IPK"; do
    magic=$(dd if="$ipk" bs=1 count=8 2>/dev/null | od -c | tr -d ' \n')
    case "$magic" in
        *'!'*'<'*'arch'*) : ;;
        *) echo "FATAL: $ipk does not look like an ar/.ipk archive (magic=$magic)"; exit 1 ;;
    esac
    echo "  $(basename "$ipk"): ar magic ok"
done

# Single-instance guard. exec_upgrade_ecu_app is unauthenticated and stays
# callable for the whole bootstrap. A second POST would spawn a concurrent
# assist that races the first on opkg, the supervisor-disable rewrite and the
# shadow edit. mkdir is atomic on this fs, so it serves as the lock. Clean it
# up on a normal EXIT.
mkdir -p "$STATE_DIR"
LOCK=$STATE_DIR/bootstrap.lock
if ! mkdir "$LOCK" 2>/dev/null; then
    # Stale-lock tolerant: a previous assist that was SIGKILLed (e.g. by the
    # lighttpd process-group teardown) leaves the lock dir behind. Read the PID
    # it recorded; if that process is gone, reclaim the lock instead of failing.
    LOCK_PID=$(cat "$LOCK/pid" 2>/dev/null || true)
    if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
        echo "FATAL: another openaps-bootstrap is running (pid $LOCK_PID, $LOCK)"
        exit 1
    fi
    echo "  stale lock $LOCK (owner pid ${LOCK_PID:-unknown} not alive) — reclaiming"
fi
printf '%s\n' "$$" > "$LOCK/pid" 2>/dev/null || true
trap 'rm -f "$LOCK/pid" 2>/dev/null; rmdir "$LOCK" 2>/dev/null' EXIT

# Backup. BusyBox tar (v1.20.x) has NO -P flag and ships NO bzip2 compressor;
# use gzip (always present). The bootstrap is purely additive: the ONLY existing
# file it modifies is /etc/shadow (the root password). So back up just
# /etc/shadow + /etc/passwd — small and fast. Everything else the bootstrap adds
# (release.pub, the opkg conf, the .ipk-installed files) is removed with `opkg
# remove` + rm, not by this rollback. (Do NOT back up /home/applications: it is
# ~20 MB of stock binaries the bootstrap never touches, and gzip'ing it pegs the
# ECU for minutes.)
BACKUP_STAMP=$(date -u +%Y%m%dT%H%M%S)
BACKUP_PATH=/home/openaps-bootstrap-backup-${BACKUP_STAMP}.tar.gz
BACKUP_SRC=""
for d in /etc/shadow /etc/passwd; do
    [ -e "$d" ] && BACKUP_SRC="$BACKUP_SRC $d"
done
tar -czf "$BACKUP_PATH" $BACKUP_SRC 2>/dev/null || {
    echo "FATAL: backup tar failed"
    exit 1
}
if [ ! -s "$BACKUP_PATH" ]; then
    echo "FATAL: backup archive is empty ($BACKUP_PATH) — refusing to proceed"
    exit 1
fi
echo "$BACKUP_PATH" > "$STATE_DIR/last-backup"
echo "  backup written: $BACKUP_PATH"

# ---------------------------------------------------------------------------
# Step 2 — plant trust + access FIRST (recovery path before anything destructive)
# ---------------------------------------------------------------------------
echo "--- step 2: plant trust anchor + root access ---"

# Trust anchor: the release public key the openaps-tls-proxy uses to verify the
# RSA signature on the opkg feed index (opkg itself enforces only MD5Sum and
# can't check signatures, so authenticity lives in the proxy).
mkdir -p "$STATE_DIR"
if [ -f "$BOOT_DIR/release.pub" ]; then
    cp -f "$BOOT_DIR/release.pub" "$RELEASE_KEY.new"
    chmod 0644 "$RELEASE_KEY.new"
    mv "$RELEASE_KEY.new" "$RELEASE_KEY"
    echo "  + $RELEASE_KEY"
else
    echo "FATAL: $BOOT_DIR/release.pub missing — refusing to proceed without trust anchor"
    exit 1
fi

# Optional bundled operator pubkey -> root's authorized_keys (only if the
# bootstrap shipped one). The guaranteed access path is the baked root password
# (set below, FATAL if it can't be); a bundled key is a convenience, so its
# absence is not fatal. ROOT_HOME is /home/root on this ECU (NOT /root).
# StrictModes requires /home/root owned root:root and .ssh 0700 /
# authorized_keys 0600. The temp lives in .ssh (same filesystem as the target)
# so the mv is an atomic same-fs rename.
if [ -f "$BOOT_DIR/authorized_keys" ]; then
    ROOT_HOME=$(awk -F: '$1=="root"{print $6; exit}' /etc/passwd 2>/dev/null)
    [ -n "$ROOT_HOME" ] || ROOT_HOME=/home/root
    mkdir -p "$ROOT_HOME"
    chown root:root "$ROOT_HOME" 2>/dev/null || true
    # StrictModes rejects the key file if the home dir is group/other-writable.
    chmod go-w "$ROOT_HOME" 2>/dev/null || true
    mkdir -p "$ROOT_HOME/.ssh"
    chown root:root "$ROOT_HOME/.ssh" 2>/dev/null || true
    chmod 700 "$ROOT_HOME/.ssh"
    AK="$ROOT_HOME/.ssh/authorized_keys"
    AK_TMP="$ROOT_HOME/.ssh/.ak.$$"
    # Build the deduped file via temp+mv only — no pre-touch, so there is never a
    # 0644-default authorized_keys window. Whole-line dedup against any existing
    # file (concatenate only files that exist) so re-running doesn't duplicate
    # the operator key.
    AK_SRC="$BOOT_DIR/authorized_keys"
    [ -f "$AK" ] && AK_SRC="$AK $AK_SRC"
    if cat $AK_SRC | awk 'NF && !/^#/ && !seen[$0]++' > "$AK_TMP"; then
        # The recovery path must be proven before anything destructive: assert the
        # deduped file is non-empty and holds at least one plausible pubkey line.
        if [ ! -s "$AK_TMP" ] \
            || ! grep -Eq '^(ssh-|ecdsa-|sk-)' "$AK_TMP"; then
            rm -f "$AK_TMP"
            echo "FATAL: deduped authorized_keys is empty or has no plausible key line (ssh-/ecdsa-/sk-)"
            exit 1
        fi
        chown root:root "$AK_TMP" 2>/dev/null || true
        chmod 600 "$AK_TMP"
        mv "$AK_TMP" "$AK"
        echo "  + $AK (operator key, deduped)"
    else
        rm -f "$AK_TMP"
        echo "FATAL: could not write $AK"
        exit 1
    fi
else
    echo "  (no bundled authorized_keys — first login is root + the baked password)"
fi

# Root password: replace root's /etc/shadow hash field with the baked $6$ hash.
# The unknown stock password is replaced, not discovered. Atomic via temp + mv.
# shadow line = name:hash:lastchg:min:max:warn:inactive:expire:flag — we rewrite
# only field 2, keeping the rest.
if [ -f "$BOOT_DIR/root.shadow.hash" ] && [ -f /etc/shadow ]; then
    NEWHASH=$(head -n 1 "$BOOT_DIR/root.shadow.hash" | tr -d '\r\n')
    case "$NEWHASH" in
        '$6$'*) : ;;
        *) echo "FATAL: root.shadow.hash is not a \$6\$ SHA-512 crypt hash"; exit 1 ;;
    esac
    SHADOW_TMP=/etc/shadow.openaps.$$
    SHADOW_ORIG_LINES=$(wc -l < /etc/shadow 2>/dev/null | tr -d ' ')
    [ -n "$SHADOW_ORIG_LINES" ] || SHADOW_ORIG_LINES=0
    # NEWHASH may contain '/' and '$', so pass it via awk -v (not sed s///).
    if awk -F: -v OFS=: -v h="$NEWHASH" \
        '$1=="root"{$2=h; seen=1} {print} END{if(!seen) exit 3}' \
        /etc/shadow > "$SHADOW_TMP"; then
        # Sanity-check the rewrite before the irreversible mv: it must be
        # non-empty, keep every original account line, and still carry a
        # well-formed root $6$ entry. A corrupt/short shadow locks the box out.
        SHADOW_NEW_LINES=$(wc -l < "$SHADOW_TMP" 2>/dev/null | tr -d ' ')
        [ -n "$SHADOW_NEW_LINES" ] || SHADOW_NEW_LINES=0
        if [ ! -s "$SHADOW_TMP" ]; then
            rm -f "$SHADOW_TMP"
            echo "FATAL: rewritten /etc/shadow is empty — refusing to install it"
            exit 1
        fi
        if [ "$SHADOW_NEW_LINES" -lt "$SHADOW_ORIG_LINES" ]; then
            rm -f "$SHADOW_TMP"
            echo "FATAL: rewritten /etc/shadow lost lines ($SHADOW_NEW_LINES < $SHADOW_ORIG_LINES) — refusing to install it"
            exit 1
        fi
        if ! grep -q '^root:\$6\$' "$SHADOW_TMP"; then
            rm -f "$SHADOW_TMP"
            echo "FATAL: rewritten /etc/shadow has no well-formed root:\$6\$ line — refusing to install it"
            exit 1
        fi
        chmod 0600 "$SHADOW_TMP"
        chown root:root "$SHADOW_TMP" 2>/dev/null || true
        mv "$SHADOW_TMP" /etc/shadow
        echo "  + /etc/shadow root password set from baked hash"
    else
        rm -f "$SHADOW_TMP"
        echo "FATAL: could not rewrite root entry in /etc/shadow (no root: line?)"
        exit 1
    fi
else
    echo "FATAL: root.shadow.hash or /etc/shadow missing — refusing to proceed"
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 3 — bring up dropbear + tls-proxy from LOCAL .ipks, then wire opkg feed
# ---------------------------------------------------------------------------
echo "--- step 3: local opkg install (dropbear, tls-proxy) + feed config ---"

if ! command -v opkg >/dev/null 2>&1; then
    echo "FATAL: opkg not found on PATH — cannot install bootstrap packages"
    exit 1
fi

# opkg scratch MUST be on /home (/tmp is a 16MB tmpfs). These dirs are also the
# ones the networked feed config below uses, so create them up front.
mkdir -p /home/openaps/opkg-tmp /home/openaps/opkg-lists
OPKG_LOCAL="opkg --tmp-dir /home/openaps/opkg-tmp"

# dropbear first — it is the recovery path. LOCAL file install, no network.
echo "  installing $(basename "$DROPBEAR_IPK")"
$OPKG_LOCAL install "$DROPBEAR_IPK" || {
    echo "FATAL: opkg install of dropbear ipk failed"
    exit 1
}

# The dropbear .ipk postinst starts dropbear; give it a moment and verify :22.
sleep 2
if ! netstat -ltn 2>/dev/null | grep -q ':22 '; then
    # Postinst may have deferred the start; try the shipped init script.
    [ -x /etc/rcS.d/S98-dropbear ] && /etc/rcS.d/S98-dropbear start || true
    sleep 2
fi
if netstat -ltn 2>/dev/null | grep -q ':22 '; then
    echo "  dropbear listening on :22 — recovery path verified"
else
    echo "FATAL: dropbear failed to bind :22 — aborting BEFORE touching the stock UI"
    echo "  rollback: tar -xzf $BACKUP_PATH -C /"
    exit 1
fi

# tls-proxy next — its S47 rcS.d init serves the persistent loopback feed.
echo "  installing $(basename "$TLSPROXY_IPK")"
$OPKG_LOCAL install "$TLSPROXY_IPK" || {
    echo "FATAL: opkg install of tls-proxy ipk failed"
    exit 1
}

# Install the networked opkg feed config so `opkg update` works over the proxy.
mkdir -p /etc/opkg
if [ -f "$BOOT_DIR/opkg-openaps.conf" ]; then
    cp -f "$BOOT_DIR/opkg-openaps.conf" "$OPKG_CONF.new"
    chmod 0644 "$OPKG_CONF.new"
    mv "$OPKG_CONF.new" "$OPKG_CONF"
    echo "  + $OPKG_CONF"
else
    echo "FATAL: $BOOT_DIR/opkg-openaps.conf missing — networked feed not configured"
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 4 — next-steps banner
# ---------------------------------------------------------------------------
# The bootstrap is purely additive: it plants trust + access and brings up
# dropbear + the opkg proxy. It deliberately does NOT touch the stock firmware
# — no disabling supervisors, no removing lighttpd. The stock stack keeps
# running; installing the OpenAPS firmware over the opkg feed is what disables
# the stock supervisors, and that is the operator's explicit next step.
echo "=== $(date) openaps-bootstrap $VERSION done ==="
echo
echo "============================================================"
echo " OpenAPS bootstrap complete."
echo
echo " Root access (both methods):"
echo "   ssh root@<ECU-IP>            # operator pubkey OR baked password"
echo
echo " Install the OpenAPS firmware over the authenticated opkg feed:"
echo
echo "   ssh root@<ECU-IP>"
echo "   opkg update"
echo "   opkg install openaps-base openaps-inv-driver openaps-ecu-zb \\"
echo "                openaps-ecu-web openaps-ecu-sunspec"
echo
echo " Rollback (if needed):"
echo "   opkg remove openaps-tls-proxy openaps-dropbear   # remove added pkgs"
echo "   tar -xzf $BACKUP_PATH -C /   # restore original root password"
echo "============================================================"
echo
exit 0
