#!/bin/sh
#
# openaps-install — master orchestrator for the brownfield OpenAPS
# installer. POSIX sh, BusyBox-safe.
#
# Layout it expects (sibling to itself):
#   ../update/applications/{inv-driver,ecu-zb,ecu-web,ecu-sunspec}
#   ../update/rcS.d/S{48,53,54,98,99}-*
#   ../update/dropbear/ (binaries + optional authorized_keys)
#   ../update/etc-openaps/release.pub
#   ../update/etc-inv-driver/settings.json.sample
#   ../update/gridprofiles/profiles/*.json
#   ../update/openaps-rollback
#
# Invoked by the stock APsystems lighttpd/CodeIgniter endpoint
# exec_upgrade_ecu_app (POST /index.php/management/exec_upgrade_ecu_app).
# Idempotent: re-running over the same version is safe.
#
# Logs to /home/openaps-install.log.

set -eu

# This orchestrator is launched by PHP under lighttpd (the stock
# exec_upgrade_ecu_app endpoint), so it is a member of lighttpd's process
# group. Killing lighttpd tears down that group and would otherwise deliver a
# signal to this script and terminate it. Ignore HUP and TERM so the install
# runs to completion regardless of who launched us. (KILL is uncatchable, which
# is why the lighttpd removal is deliberately the LAST step — see step 10.)
# This is re-armed alongside the lock-cleanup EXIT trap once $STATE_DIR exists.
trap '' HUP TERM

# Stamped by `make package-openaps` (sed-substitutes this line with the build
# version). The literal default is the fallback when run unpackaged.
VERSION="__OPENAPS_VERSION__"
case "$VERSION" in __OPENAPS_VERSION__|"") VERSION="dev" ;; esac
LOG=/home/openaps-install.log
STATE_DIR=/etc/openaps
RELEASE_KEY=$STATE_DIR/release.pub
SETTINGS_PATH=/etc/inv-driver/settings.json
MAC_CONF=/etc/yuneng/ecu_eth0_mac.conf
ECUID_CONF=/etc/yuneng/ecuid.conf
NEED_KB=51200    # ~50 MB in /home

exec >> "$LOG" 2>&1
echo
echo "=== $(date) openaps-install $VERSION starting ==="

ASSIST_DIR=$(cd "$(dirname "$0")" && pwd)
PKG_ROOT=$(cd "$ASSIST_DIR/.." && pwd)
SRC=$PKG_ROOT/update

if [ ! -d "$SRC" ]; then
    echo "FATAL: payload directory $SRC not found"
    exit 1
fi

# Single-instance guard. exec_upgrade_ecu_app is unauthenticated and stays
# callable for the whole install (steps 7-9 take ~40s, mostly the step-8
# sleep 30). A second POST would spawn a concurrent assist that races the first
# on service start, killall, the $DISABLED_LIST rewrite and the installed.json
# write. mkdir is atomic on this fs, so it serves as the lock. Clean it up on a
# normal EXIT; keep ignoring HUP/TERM (merged with the trap above) so a signal
# from lighttpd's process-group teardown still can't kill us mid-install.
mkdir -p "$STATE_DIR"
LOCK=$STATE_DIR/install.lock
if ! mkdir "$LOCK" 2>/dev/null; then
    echo "FATAL: another openaps-install is running ($LOCK)"
    exit 1
fi
trap '' HUP TERM
trap 'rmdir "$LOCK" 2>/dev/null' EXIT

# ---------------------------------------------------------------------------
# Step 1 — pre-flight
# ---------------------------------------------------------------------------
echo "--- step 1: pre-flight ---"

# Disk: BusyBox df -k. Available column = 4th field on the data line.
AVAIL=$(df -k /home 2>/dev/null | awk 'NR==2 {print $4}')
if [ -z "$AVAIL" ] || [ "$AVAIL" -lt "$NEED_KB" ]; then
    echo "FATAL: insufficient free space in /home (have ${AVAIL:-0} KB, need $NEED_KB KB)"
    exit 1
fi
echo "  disk ok: ${AVAIL} KB free in /home"

if [ ! -f "$MAC_CONF" ]; then
    echo "FATAL: $MAC_CONF missing — ECU not provisioned"
    exit 1
fi
echo "  $MAC_CONF present"

# Verify ARMv7 ELF on payload binaries (busybox file fallback: check magic).
for bin in inv-driver ecu-zb ecu-web ecu-sunspec; do
    p="$SRC/applications/$bin"
    if [ ! -f "$p" ]; then
        echo "FATAL: missing binary $p"
        exit 1
    fi
    # ELF magic: 0x7f 'E' 'L' 'F'. The ECU's BusyBox od (v1.20.x) does NOT
    # support -A/-t/-N (only the flags in `od [-aBbcDdeFfHhIiLlOovXx]`), so we
    # read 4 bytes and render with plain `od -c` — the one widely-available
    # mode. 0x7f prints as the octal escape 177; a leading offset column is
    # harmless because we glob-match the magic anywhere in the rendered line.
    magic=$(dd if="$p" bs=1 count=4 2>/dev/null | od -c | tr -d ' \n')
    case "$magic" in
        *177ELF*) : ;;
        *) echo "FATAL: $p does not look like ELF (magic=$magic)"; exit 1 ;;
    esac
    echo "  $bin: ELF ok"
done

# ---------------------------------------------------------------------------
# Step 2 — backup
# ---------------------------------------------------------------------------
echo "--- step 2: backup ---"

BACKUP_STAMP=$(date -u +%Y%m%dT%H%M%S)
BACKUP_PATH=/home/openaps-backup-${BACKUP_STAMP}.tar.gz

# BusyBox tar (v1.20.x) has NO -P flag and ships NO bzip2 *compressor* (only a
# built-in bunzip2 for extraction) — `tar -cjf` would "succeed" with exit 0 yet
# write a 0-byte file. So we compress with gzip (always present) and let
# rollback restore with -C / (BusyBox strips the leading '/' from member names).
# Only back up paths that exist, so a missing optional dir doesn't abort.
BACKUP_SRC=""
for d in /home/applications /etc/rcS.d /etc/init.d /etc/yuneng; do
    [ -e "$d" ] && BACKUP_SRC="$BACKUP_SRC $d"
done
tar -czf "$BACKUP_PATH" $BACKUP_SRC 2>/dev/null || {
    echo "FATAL: backup tar failed"
    exit 1
}
if [ ! -s "$BACKUP_PATH" ]; then
    echo "FATAL: backup archive is empty ($BACKUP_PATH) — refusing to proceed"
    exit 1
fi

echo "$BACKUP_PATH" > "$STATE_DIR/last-backup"
echo "  backup written: $BACKUP_PATH"

# ---------------------------------------------------------------------------
# Step 3 — DROPBEAR FIRST (recovery path)
# ---------------------------------------------------------------------------
echo "--- step 3: install dropbear (recovery path) ---"

DROPBEAR_INSTALLED=0
if [ -d "$SRC/dropbear" ] && [ -f "$SRC/dropbear/dropbear" ]; then
    for f in dropbear dropbearkey dropbearconvert dbclient; do
        if [ -f "$SRC/dropbear/$f" ]; then
            mkdir -p /usr/local/sbin
            cp -f "$SRC/dropbear/$f" /usr/local/sbin/$f.new
            chmod 0755 /usr/local/sbin/$f.new
            mv /usr/local/sbin/$f.new /usr/local/sbin/$f
            echo "  + /usr/local/sbin/$f"
        fi
    done

    mkdir -p /etc/dropbear
    if [ ! -f /etc/dropbear/dropbear_rsa_host_key ] && [ -x /usr/local/sbin/dropbearkey ]; then
        /usr/local/sbin/dropbearkey -t rsa -f /etc/dropbear/dropbear_rsa_host_key 2>/dev/null || true
        echo "  + /etc/dropbear/dropbear_rsa_host_key (generated)"
    fi

    # recoveryd owns authorized_keys. Install its binary + init script so
    # it renders the key list at boot (before S98-dropbear), then SEED
    # /etc/recoveryd/access.json from the operator's bundled key instead of
    # writing /root/.ssh/authorized_keys directly. recoveryd renders the
    # file on its next start.
    if [ -f "$SRC/applications/recoveryd" ]; then
        mkdir -p /home/applications/recoveryd
        cp -f "$SRC/applications/recoveryd" /home/applications/recoveryd/recoveryd.new
        chmod 0755 /home/applications/recoveryd/recoveryd.new
        mv /home/applications/recoveryd/recoveryd.new /home/applications/recoveryd/recoveryd
        echo "  + /home/applications/recoveryd/recoveryd"
    fi
    if [ -f "$SRC/rcS.d/S97-recoveryd" ]; then
        cp -f "$SRC/rcS.d/S97-recoveryd" /etc/rcS.d/S97-recoveryd.new
        chmod 0755 /etc/rcS.d/S97-recoveryd.new
        mv /etc/rcS.d/S97-recoveryd.new /etc/rcS.d/S97-recoveryd
        echo "  + /etc/rcS.d/S97-recoveryd"
    fi

    if [ -f "$SRC/dropbear/authorized_keys" ]; then
        if [ -x /home/applications/recoveryd/recoveryd ]; then
            mkdir -p /etc/recoveryd
            # Seed access.json (merge, idempotent). recoveryd validates and
            # fingerprints each key; it renders /root/.ssh/authorized_keys on
            # its next start.
            if /home/applications/recoveryd/recoveryd seed \
                    -access /etc/recoveryd/access.json \
                    -provider openaps \
                    -from "$SRC/dropbear/authorized_keys"; then
                echo "  + /etc/recoveryd/access.json (seeded from bundled key)"
            else
                echo "FATAL: recoveryd seed failed — refusing to continue without a recovery key"
                echo "  rollback: tar -xzf $BACKUP_PATH -C /"
                exit 1
            fi
        else
            # No recoveryd binary in this package — fall back to writing
            # authorized_keys directly so the recovery path still exists.
            ROOT_HOME=$(awk -F: '$1=="root"{print $6; exit}' /etc/passwd 2>/dev/null)
            [ -n "$ROOT_HOME" ] || ROOT_HOME=/root
            chown root:root "$ROOT_HOME" 2>/dev/null || true
            mkdir -p "$ROOT_HOME/.ssh"
            chown root:root "$ROOT_HOME/.ssh"
            chmod 700 "$ROOT_HOME/.ssh"
            touch "$ROOT_HOME/.ssh/authorized_keys"
            cat "$SRC/dropbear/authorized_keys" >> "$ROOT_HOME/.ssh/authorized_keys"
            awk '!seen[$0]++' "$ROOT_HOME/.ssh/authorized_keys" > /tmp/.ak.tmp \
                && mv /tmp/.ak.tmp "$ROOT_HOME/.ssh/authorized_keys"
            chown root:root "$ROOT_HOME/.ssh/authorized_keys"
            chmod 600 "$ROOT_HOME/.ssh/authorized_keys"
            echo "  + $ROOT_HOME/.ssh/authorized_keys (no recoveryd — direct write)"
        fi
    fi

    # Start recoveryd so it renders authorized_keys + ensures the host key
    # BEFORE dropbear binds. We don't abort the install if it fails to come
    # up (dropbear's own host-key gen below is the backstop and the key was
    # already seeded into access.json, so a later reboot's boot-render
    # recovers), but a silent boot-render failure shouldn't pass unnoticed:
    # check the exit status and that the socket appeared, and warn loudly.
    if [ -x /etc/rcS.d/S97-recoveryd ]; then
        if /etc/rcS.d/S97-recoveryd start; then
            if [ -S /run/recoveryd.sock ]; then
                echo "  recoveryd up — authorized_keys rendered, socket ready"
            else
                echo "  WARNING: recoveryd start returned ok but /run/recoveryd.sock is absent"
            fi
        else
            echo "  WARNING: recoveryd failed to start (boot-render may not have run)."
            echo "           access.json was seeded; a reboot's boot-render is the backstop."
            echo "           dropbear host-key gen below also still runs. Check the recoveryd log."
        fi
    fi

    if [ -f "$SRC/rcS.d/S98-dropbear" ]; then
        cp -f "$SRC/rcS.d/S98-dropbear" /etc/rcS.d/S98-dropbear.new
        chmod 0755 /etc/rcS.d/S98-dropbear.new
        mv /etc/rcS.d/S98-dropbear.new /etc/rcS.d/S98-dropbear
        echo "  + /etc/rcS.d/S98-dropbear"
    fi

    # Start dropbear and verify it is listening on :22.
    /etc/rcS.d/S98-dropbear start || true
    sleep 2
    if netstat -ltn 2>/dev/null | grep -q ':22 '; then
        echo "  dropbear listening on :22 — recovery path verified"
        DROPBEAR_INSTALLED=1
    else
        echo "FATAL: dropbear failed to bind :22 — aborting BEFORE removing lighttpd"
        echo "  rollback: tar -xzf $BACKUP_PATH -C /"
        exit 1
    fi
else
    # No bundled dropbear. A pre-existing SSH on :22 OR telnet on :23 is
    # acceptable as a recovery path — either lets the operator log in and
    # roll back if the lighttpd removal in step 10 leaves the box wedged.
    if netstat -ltn 2>/dev/null | grep -q ':22 '; then
        echo "  dropbear already listening on :22 (no bundle supplied)"
        DROPBEAR_INSTALLED=1
    elif netstat -ltn 2>/dev/null | grep -q ':23 '; then
        echo "  telnet listening on :23 — recovery path verified (no dropbear)"
        DROPBEAR_INSTALLED=1
    else
        echo "FATAL: no dropbear bundle, no SSH on :22, no telnet on :23 — no recovery path"
        echo "  rollback: tar -xzf $BACKUP_PATH -C /"
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Step 4 — provision OpenAPS settings (idempotent)
# ---------------------------------------------------------------------------
echo "--- step 4: provision OpenAPS settings ---"

mkdir -p /etc/inv-driver
if [ -f "$SETTINGS_PATH" ]; then
    echo "  $SETTINGS_PATH already exists — keeping operator-edited config"
else
    # Build a fresh settings.json from /etc/yuneng/ecu_eth0_mac.conf +
    # /etc/yuneng/ecuid.conf. Format expected by inv-driver internal/settings.
    MAC_RAW=$(cat "$MAC_CONF" 2>/dev/null | tr -d '[:space:]' | head -c 32)
    # Strip any colons / dashes if present.
    MAC_HEX=$(echo "$MAC_RAW" | tr -d ':-' | tr 'A-F' 'a-f')
    if [ -z "$MAC_HEX" ] || [ ${#MAC_HEX} -lt 12 ]; then
        echo "WARN: $MAC_CONF content unparseable; settings.json left for first-run autodetect"
    else
        # Lower 16 bits of MAC → PAN override (uppercase hex, 4 chars).
        PAN_HEX=$(echo "$MAC_HEX" | tail -c 5 | tr 'a-f' 'A-F')
        # Re-format MAC as colon-separated for cosmetics.
        MAC_FMT=$(echo "$MAC_HEX" | sed 's/\(..\)/\1:/g;s/:$//')
        ECU_ID=""
        if [ -f "$ECUID_CONF" ]; then
            ECU_ID=$(cat "$ECUID_CONF" 2>/dev/null | tr -d '[:space:]')
        fi
        cat > "$SETTINGS_PATH.new" <<EOF
{
  "ecu_id": "$ECU_ID",
  "mac": "$MAC_FMT",
  "pan_override": "$PAN_HEX",
  "zigbee_type": "apsystems",
  "channel": 16
}
EOF
        chmod 0600 "$SETTINGS_PATH.new"
        mv "$SETTINGS_PATH.new" "$SETTINGS_PATH"
        echo "  + $SETTINGS_PATH (ecu_id=$ECU_ID mac=$MAC_FMT pan=$PAN_HEX)"
    fi
fi

# Stage release.pub for future signed-tarball OTAs.
if [ -f "$SRC/etc-openaps/release.pub" ] && [ ! -f "$RELEASE_KEY" ]; then
    cp -f "$SRC/etc-openaps/release.pub" "$RELEASE_KEY.new"
    chmod 0644 "$RELEASE_KEY.new"
    mv "$RELEASE_KEY.new" "$RELEASE_KEY"
    echo "  + $RELEASE_KEY"
fi

# ---------------------------------------------------------------------------
# Step 5 — install OpenAPS binaries + init scripts (atomic)
# ---------------------------------------------------------------------------
echo "--- step 5: install OpenAPS binaries + init scripts ---"

put_atomic() {
    src=$1
    dst=$2
    mode=$3
    mkdir -p "$(dirname "$dst")"
    cp -f "$src" "$dst.new"
    chmod "$mode" "$dst.new"
    mv "$dst.new" "$dst"
    echo "  + $dst"
}

mkdir -p /home/applications/inv-driver /home/applications/ecu-zb/run /home/applications/ecu-zb/log
mkdir -p /home/applications/ecu-web /home/applications/recoveryd
# NOTE: ecu-sunspec is a BARE binary at /home/applications/ecu-sunspec (matching
# S99-sunspec's BIN=). Do NOT mkdir that path — it would turn the binary's
# destination into a directory and put_atomic's `mv` would drop the binary
# inside it as ecu-sunspec/ecu-sunspec.new instead of installing it.
mkdir -p /var/lib/inv-driver /var/lib/ecu-web

put_atomic "$SRC/applications/inv-driver"  /home/applications/inv-driver/inv-driver    0755
put_atomic "$SRC/applications/ecu-zb"      /home/applications/ecu-zb/ecu-zb            0755
put_atomic "$SRC/applications/ecu-web"     /home/applications/ecu-web/ecu-web          0755
put_atomic "$SRC/applications/ecu-sunspec" /home/applications/ecu-sunspec              0755
# recoveryd owns the SSH access plane. Step 3 already installs+starts it when a
# dropbear bundle is present; install here too so it ships on every package.
[ -f "$SRC/applications/recoveryd" ] && \
    put_atomic "$SRC/applications/recoveryd" /home/applications/recoveryd/recoveryd 0755

for s in S48-inv-driver S53-ecu-zb S54-ecu-web S97-recoveryd S99-sunspec; do
    if [ -f "$SRC/rcS.d/$s" ]; then
        put_atomic "$SRC/rcS.d/$s" "/etc/rcS.d/$s" 0755
    fi
done

# Provision the base grid-profile library so the console has profiles to select
# on first boot. inv-driver loads these from <gridprofiles-dir>/profiles/ at
# startup; without them gp_base_profiles is empty and nothing is selectable.
# Operator overlays live in a separate overlays/ dir and are not touched here.
if [ -d "$SRC/gridprofiles/profiles" ]; then
    mkdir -p /var/lib/inv-driver/gridprofiles/profiles
    n=0
    for f in "$SRC"/gridprofiles/profiles/*.json; do
        [ -f "$f" ] || continue
        cp -f "$f" /var/lib/inv-driver/gridprofiles/profiles/ && n=$((n+1))
    done
    chmod 0644 /var/lib/inv-driver/gridprofiles/profiles/*.json 2>/dev/null || true
    echo "  + grid profiles -> /var/lib/inv-driver/gridprofiles/profiles ($n)"
fi

# Seed inv-driver's inverter inventory from the stock APsystems DB so a
# mid-day brownfield migration polls the already-paired fleet immediately
# instead of waiting for the next dawn re-announce. Runs here (not in step 4)
# because it needs both the provisioned settings AND the installed binary.
# Best-effort: a failure must never abort the install.
STOCK_DB=/home/database.db
INV_DRIVER_BIN=/home/applications/inv-driver/inv-driver
if [ -f "$STOCK_DB" ] && [ -x "$INV_DRIVER_BIN" ]; then
    echo "  seeding inventory from $STOCK_DB"
    if "$INV_DRIVER_BIN" import-stock -stock-db "$STOCK_DB" -db /var/lib/inv-driver/state.db; then
        :
    else
        echo "WARN: import-stock failed (continuing install; inverters will seed on next announce)"
    fi
else
    echo "  no $STOCK_DB (or binary missing) — skipping inventory seed"
fi

# ---------------------------------------------------------------------------
# Step 6 — DISABLE stock supervisors (init removal via binary removal)
# ---------------------------------------------------------------------------
# The manager binary system()-spawns each stock app ONCE at boot. Each
# supervisor (*monitor*) is then its own respawn loop for its child.
# Disable by:
#   a) killing the running process(es)
#   b) removing the binary so manager's next-boot spawn no-ops
# This is init-level removal: no sleeper stubs, no .real swap files.
# A supervisor with no binary on disk simply never runs again. Restored
# from the backup tarball by openaps-rollback.
echo "--- step 6: disable stock supervisors ---"

DISABLED_LIST="$STATE_DIR/disabled-apps.list"
: > "$DISABLED_LIST"

# NOTE: idwriter is deliberately NOT in this list. It is the stock provisioning
# daemon on TCP :4540 (unauthenticated root command surface — the `A108:` shell
# verb). We keep it running so the migrated box retains a LAN recovery path if
# dropbear ever fails to come up. This is an intentional trade-off: it leaves an
# unauthenticated root surface on the LAN. Remove it from the box (or add it
# here) if that is not acceptable for a given deployment.
DISABLE_SET="
monitor.exe
clientmonitor
control_client_monitor
gprsmonitor
mqtt_monitor.exe
phone_server_monitor
phone_server_app_monitor
lancommClientMonitor
single_update_monitor
updatemanager
autoupdate2
autoupdate_restart
AutoUpInver2
AutoUpInver
autoupdate
autoupdate_main_restart
resmonitor
usbTest
quectel_monitor.exe
4gmonitor.exe
diagnosis_network
slave485
"

for app in $DISABLE_SET; do
    # Live kill (best-effort; some names won't be running).
    if pidof "$app" >/dev/null 2>&1; then
        killall -q "$app" 2>/dev/null || true
        sleep 1
        killall -q -9 "$app" 2>/dev/null || true
    fi

    # Remove the binary so the next boot's manager system() no-ops.
    BIN_PATH=/home/applications/$app
    if [ -f "$BIN_PATH" ]; then
        # Move into a holding dir so rollback can restore even if backup
        # tar can't find them (defensive — backup already captured them).
        # Copy-then-remove so a failed cross-device move can't delete the only
        # copy; these are also in the step-2 tarball, but keep it consistent
        # with the lighttpd handling in step 10.
        mkdir -p "$STATE_DIR/disabled-bin"
        cp -f "$BIN_PATH" "$STATE_DIR/disabled-bin/$app"
        rm -f "$BIN_PATH"
        echo "$app" >> "$DISABLED_LIST"
        echo "  disabled: $app"
    fi
done

# Also kill direct children of the now-defunct supervisors so they don't
# keep running until reboot.
for child in main.exe client control_client gprs mqtt.exe phone_server lancommClient single_update autoupdate quectel-CM; do
    if pidof "$child" >/dev/null 2>&1; then
        killall -q "$child" 2>/dev/null || true
    fi
done

# ---------------------------------------------------------------------------
# Step 7 — start OpenAPS services
# ---------------------------------------------------------------------------
echo "--- step 7: start OpenAPS services ---"

for s in S48-inv-driver S53-ecu-zb S54-ecu-web S99-sunspec; do
    init=/etc/rcS.d/$s
    [ -x "$init" ] || continue
    echo "  starting $s"
    "$init" start || echo "  WARN: $s start exit $?"
    sleep 2
done

# ---------------------------------------------------------------------------
# Step 8 — smoke verify
# ---------------------------------------------------------------------------
echo "--- step 8: smoke verify ---"

SMOKE_OK=1

if [ -S /var/run/inv-driver.sock ]; then
    echo "  ok: inv-driver UDS present"
else
    echo "  WARN: /var/run/inv-driver.sock missing"
    SMOKE_OK=0
fi

# ecu-web health probe. We don't ship a /api/health; /api/auth/status is
# the always-reachable endpoint and indicates the HTTP/2 server is up.
if command -v curl >/dev/null 2>&1; then
    if curl -sk --max-time 5 https://localhost:443/api/auth/status >/dev/null 2>&1; then
        echo "  ok: ecu-web /api/auth/status reachable"
    else
        echo "  WARN: ecu-web /api/auth/status not reachable yet"
        SMOKE_OK=0
    fi
fi

# Wait 30s for ecu-zb to come up and ingest its first frame.
echo "  waiting 30s for ecu-zb / first telemetry frame ..."
sleep 30

if [ -f /home/applications/ecu-zb/log/ecu-zb.log ]; then
    if grep -qi 'coordinator\|configured\|started' /home/applications/ecu-zb/log/ecu-zb.log 2>/dev/null; then
        echo "  ok: ecu-zb reports coordinator state"
    else
        echo "  WARN: ecu-zb log has no coordinator state line yet"
    fi
fi

# ---------------------------------------------------------------------------
# Step 9 — audit + install rollback CLI
# ---------------------------------------------------------------------------
echo "--- step 9: audit + rollback CLI ---"

if [ -f "$SRC/openaps-rollback" ]; then
    put_atomic "$SRC/openaps-rollback" /usr/local/bin/openaps-rollback 0755
fi

GIT_SHA=$(cat "$SRC/etc-openaps/git-sha" 2>/dev/null || echo "unknown")
DISABLED_JSON=$(awk 'BEGIN{printf "["} {printf "%s\"%s\"", (NR>1?",":""), $0} END{printf "]"}' "$DISABLED_LIST")
TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)

cat > "$STATE_DIR/installed.json.new" <<EOF
{
  "version": "$VERSION",
  "ts": "$TS",
  "backup_path": "$BACKUP_PATH",
  "git_sha": "$GIT_SHA",
  "smoke_ok": $SMOKE_OK,
  "disabled_apps": $DISABLED_JSON
}
EOF
mv "$STATE_DIR/installed.json.new" "$STATE_DIR/installed.json"
echo "  + $STATE_DIR/installed.json"

echo "$TS $VERSION installed (smoke_ok=$SMOKE_OK backup=$BACKUP_PATH)" >> "$LOG"

# ---------------------------------------------------------------------------
# Step 10 — remove lighttpd / CodeIgniter (stock UI) — DELIBERATELY LAST
# ---------------------------------------------------------------------------
# assist is a member of lighttpd's process group (PHP under lighttpd launched
# us). Killing lighttpd tears down that group, and a KILL/group teardown is
# uncatchable — the trap at the top can't save us. So this is the LAST thing we
# do: by now OpenAPS is installed, started, smoke-verified, the rollback CLI is
# in place and installed.json is written, so a death at the killall below loses
# nothing. ecu-web (:443), ecu-sunspec (:502) and stock lighttpd (:80) don't
# collide, so OpenAPS was started in step 7 while lighttpd was still up. The
# trade-off is that the stock unauthenticated surface (exec_upgrade_ecu_app et
# al.) stays live for the ~40s of steps 7-9; the single-instance lock taken at
# the top prevents a second POST racing a concurrent install through that window.
#
# We also neutralize lighttpd on disk BEFORE the killall: move the binary aside
# and disable any rcS.d/init.d entry first. That way, even if assist dies at the
# killall, lighttpd is already gone from the boot path and won't come back.
echo "--- step 10: remove lighttpd / CodeIgniter ---"

if [ "$DROPBEAR_INSTALLED" -ne 1 ]; then
    echo "FATAL: dropbear not verified; refusing to touch lighttpd"
    exit 1
fi

# lighttpd is launched by manager via system() from /usr/local/lighttpd/sbin/.
# Neutralize on disk first: move the binary aside so the next boot's spawn
# no-ops even if we're killed at the killall below.
LIGHTTPD_BIN=/usr/local/lighttpd/sbin/lighttpd
if [ -f "$LIGHTTPD_BIN" ]; then
    mkdir -p "$STATE_DIR/disabled-bin"
    # Non-destructive: copy first, and only remove the original once the copy
    # lands. /usr/local/lighttpd is NOT in the step-2 backup tarball and
    # openaps-rollback restores lighttpd ONLY from disabled-bin/, so a plain
    # `mv ... || rm -f` that lost the copy (e.g. a cross-device mv that failed)
    # would leave the stock UI permanently unrecoverable. No `|| rm -f`
    # fallback: under set -e a copy failure aborts rather than deleting the
    # sole binary.
    cp -f "$LIGHTTPD_BIN" "$STATE_DIR/disabled-bin/lighttpd"
    rm -f "$LIGHTTPD_BIN"
    # This lands in $DISABLED_LIST after installed.json was already written in
    # step 9, so installed.json's disabled_apps omits lighttpd. Harmless:
    # openaps-rollback restores from disabled-bin/, not from installed.json.
    echo "lighttpd" >> "$DISABLED_LIST"
    echo "  disabled: lighttpd"
fi

# Some firmwares additionally start lighttpd from rcS.d. Disable any such entry
# now, also before the killall.
for f in /etc/rcS.d/S*lighttpd* /etc/init.d/lighttpd* /etc/init.d/S*lighttpd*; do
    [ -e "$f" ] || continue
    mkdir -p "$STATE_DIR/disabled-init"
    mv "$f" "$STATE_DIR/disabled-init/$(basename "$f")" 2>/dev/null || rm -f "$f"
    echo "  disabled init: $f"
done

# Binary and boot entries are gone; NOW kill the running process. If this kills
# assist too, the install is already complete and persistent. Emit the marker
# first so a successful-but-killed run is distinguishable in the log from one
# that died earlier in step 10. Release the lock here too: a SIGKILL at the
# killall would skip the EXIT trap and leave a stale lock that blocks re-runs,
# and the concurrency window is already over by this point.
echo "  install complete and persistent; killing lighttpd (assist may not survive)"
rmdir "$LOCK" 2>/dev/null || true
if pidof lighttpd >/dev/null 2>&1; then
    killall -q lighttpd 2>/dev/null || true
    sleep 1
    killall -q -9 lighttpd 2>/dev/null || true
fi

echo "=== $(date) openaps-install $VERSION done ==="
echo
echo "To roll back: ssh root@<ECU-IP> /usr/local/bin/openaps-rollback"
echo

# Reboot to start OpenAPS cleanly. The services launched in step 7 share
# assist's process group (PHP-under-lighttpd launched us) and were torn down
# when lighttpd was killed above — step 7 only validates that they start; the
# real run comes from init at boot, outside any web process group. Everything
# is on disk (binaries, init scripts, settings, seeded inventory, grid
# profiles), the operator's HTTP call already returned `res:0`, and the stock
# stack is disabled, so the reboot is transparent and lands on working OpenAPS.
echo "=== rebooting to start OpenAPS via init (console returns in ~1-2 min) ==="
sync
sleep 2
# `reboot` is not on PATH in this context (it lives in /sbin); try explicit
# paths and the BusyBox applet before falling back to the sysrq trigger.
/sbin/reboot 2>/dev/null || reboot 2>/dev/null || busybox reboot 2>/dev/null || {
    echo b > /proc/sysrq-trigger 2>/dev/null
}
exit 0
