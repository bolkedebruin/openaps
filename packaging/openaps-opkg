#!/bin/sh
# On-demand opkg front-end. Starts openaps-tls-proxy on loopback, waits for it
# to bind, runs opkg through it, and lets the proxy self-exit once idle.
set -eu

PROXY=/home/applications/openaps-tls-proxy/openaps-tls-proxy
CONF=/home/applications/openaps-tls-proxy/opkg-openaps.conf
UPSTREAM=https://bolkedebruin.github.io/openaps-feed/stable
LISTEN=127.0.0.1:8071

# Start the proxy in the background. It self-exits after a short idle window,
# so a normal opkg run leaves nothing behind.
"$PROXY" -listen "$LISTEN" -upstream "$UPSTREAM" -idle-timeout 30s &
PROXY_PID=$!

# Wait for the loopback port to accept connections before driving opkg. Bail
# out if the proxy died (bad pubkey, port taken, loopback check failed) rather
# than letting opkg run against a feed that never came up.
i=0
up=0
while [ "$i" -lt 50 ]; do
	if ! kill -0 "$PROXY_PID" 2>/dev/null; then
		echo "openaps-opkg: proxy exited before binding $LISTEN" >&2
		wait "$PROXY_PID" 2>/dev/null || true
		exit 1
	fi
	if nc -z 127.0.0.1 8071 2>/dev/null; then
		up=1
		break
	fi
	i=$((i + 1))
	usleep 100000 2>/dev/null || sleep 1
done
if [ "$up" -ne 1 ]; then
	echo "openaps-opkg: proxy did not bind $LISTEN in time" >&2
	kill "$PROXY_PID" 2>/dev/null || true
	exit 1
fi

exec opkg -f "$CONF" "$@"
