{
    "id": 64202,
    "group": {
        "name": "apsystems_ecu",
        "label": "APsystems ECU vendor extras",
        "desc": "Vendor model emitted by ecu-sunspec. System-wide energy aggregates, ECU info, and per-inverter metadata that don't fit standard SunSpec fields.",
        "type": "group",
        "points": [
            {
                "name": "ID",
                "value": 64202,
                "desc": "Model identifier",
                "label": "Model ID",
                "mandatory": "M",
                "static": "S",
                "size": 1,
                "type": "uint16"
            },
            {
                "name": "L",
                "desc": "Model length",
                "label": "Model Length",
                "mandatory": "M",
                "static": "S",
                "size": 1,
                "type": "uint16"
            },
            {
                "name": "PollingS",
                "type": "uint16",
                "size": 1,
                "label": "Polling Interval",
                "desc": "ECU radio polling cadence (seconds).",
                "units": "Secs"
            },
            {
                "name": "EcuFwVer",
                "type": "string",
                "size": 8,
                "label": "ECU Firmware Version",
                "desc": "/etc/yuneng/version.conf"
            },
            {
                "name": "TodayWh",
                "type": "acc32",
                "size": 2,
                "label": "Today Energy",
                "desc": "Energy produced since midnight, derived from historical_data.db.daily_energy.",
